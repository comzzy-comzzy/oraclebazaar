# Pick pharos-testnet or pharos-mainnet.
PHAROS_NETWORK=pharos-testnet

# Optional custom RPC URL. Defaults are in src/networks.ts.
PHAROS_RPC_URL=

# Required only for write commands such as deploy-registry, register-provider,
# publish-attestation, and buy-signal when onchain anchoring is enabled.
PRIVATE_KEY=

# Optional predeployed OracleBazaarRegistry address.
ORACLEBAZAAR_REGISTRY=

# Optional default x402 facilitator URL used by some sellers.
X402_FACILITATOR_URL=
